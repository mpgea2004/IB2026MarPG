    <string name="legal_title_finalidad">Finalidad del tratamiento</string>
    <string name="legal_content_finalidad">Sus datos serán tratados para la prestación del servicio de facturación electrónica, envío de avisos de disponibilidad de factura en su email y gestión del área de cliente, además del cumplimiento de obligaciones legales.</string>
